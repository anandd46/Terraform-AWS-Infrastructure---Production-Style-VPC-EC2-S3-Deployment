############################################################
# terraform.tfvars.example
#
# Copy this file to "terraform.tfvars" and customize the
# values below before running `terraform apply`.
#
#   cp terraform.tfvars.example terraform.tfvars
#
# NOTE: terraform.tfvars is intentionally excluded via
# .gitignore because it often contains environment-specific
# or sensitive values (like your admin IP address).
############################################################

aws_region   = "us-east-1"
environment  = "production"
owner        = "your-name"
project_name = "production-style-vpc"

vpc_cidr              = "10.0.0.0/16"
availability_zones    = ["us-east-1a", "us-east-1b"]
public_subnet_cidrs   = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs  = ["10.0.11.0/24", "10.0.12.0/24"]

# Set to false + enable_nat_instance = true to use the Free Tier
# NAT Instance alternative instead of a billed NAT Gateway.
enable_nat_gateway  = true
enable_nat_instance = false

instance_type      = "t2.micro"
nat_instance_type  = "t2.micro"
key_pair_name      = "production-vpc-keypair"

# IMPORTANT: Replace with YOUR public IP in CIDR notation.
# Find it at: https://checkip.amazonaws.com
admin_ip_cidr = "203.0.113.10/32"

allowed_web_ports = [80, 443]

common_tags = {
  Project   = "Production-Style-AWS-VPC"
  ManagedBy = "Terraform"
}
